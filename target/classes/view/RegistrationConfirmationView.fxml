<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="10.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label style="-fx-font-size: 18px;" text="Confirm your registration" />
      <ListView fx:id="summaryListView" prefHeight="150.0" prefWidth="400.0" />
      <Label text="Enter 6-digit Confirmation code" />
      <TextField fx:id="confirmationCodeField" prefWidth="150.0" />
      <HBox alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#submitConfirmationHandler" text="Submit" />
            <Button fx:id="backToCartSelection" mnemonicParsing="false" onAction="#backToCartHandler" text="Back to Cart Selection" />
            <Button fx:id="returnHomeButton" mnemonicParsing="false" onAction="#returnHomeHandler" text="return home" />
         </children>
      </HBox>
      <Label fx:id="resultLabel" textFill="#00ff11" />
   </children>
</VBox>
