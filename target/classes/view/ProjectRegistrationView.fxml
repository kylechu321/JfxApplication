<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" spacing="10.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label style="-fx-font-size: 18px;" text="Project Registration" />
      <ComboBox fx:id="projectComboBox" prefWidth="200.0" />
      <HBox prefHeight="35.0" prefWidth="600.0" spacing="10.0">
         <children>
            <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Hours per slot: " />
            <Spinner fx:id="hoursSpinner" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" />
            <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Number of Slots: " />
            <Spinner fx:id="slotsSpinner" maxWidth="1.7976931348623157E308" />
         </children>
      </HBox>
      <HBox alignment="CENTER">
         <children>
            <Button fx:id="addToCartButton" mnemonicParsing="false" onAction="#addToCartHandler" text="Add to Cart" />
            <Button fx:id="removeCartButton" mnemonicParsing="false" onAction="#removeCartSelectedHandler" text="remove cart" />
            <Button fx:id="updateCartButton" mnemonicParsing="false" onAction="#updateCartSelectedHandler" text="update cart" />
         </children>
      </HBox>
      <ListView fx:id="cartListView" prefHeight="150.0" prefWidth="300.0" />
      <HBox alignment="CENTER">
         <children>
            <Button fx:id="confirmButton" mnemonicParsing="false" onAction="#confirmRegistrationHandler" text="Confirm Registration" />
         </children>
      </HBox>
      <Label fx:id="errorMessageLabel" textFill="RED" />
   </children>
   <padding>
      <Insets top="20.0" />
   </padding>
</VBox>
