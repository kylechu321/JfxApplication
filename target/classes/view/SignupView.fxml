<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="10.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <Label fx:id="status" />
      <Label layoutX="83.0" layoutY="72.0" prefHeight="17.0" prefWidth="250.0" text="First Name" />
      <TextField fx:id="firstName" layoutX="83.0" layoutY="64.0" maxWidth="250.0" />
      <Label layoutX="85.0" layoutY="61.0" prefHeight="17.0" prefWidth="250.0" text="Last Name" />
      <TextField fx:id="lastName" layoutX="85.0" layoutY="101.0" maxWidth="250.0" />
      <Label prefHeight="17.0" prefWidth="250.0" text="Email Address" />
      <TextField fx:id="email" maxWidth="250.0" />
        <Label prefHeight="17.0" prefWidth="250.0" text="Username" />
        <TextField fx:id="username" maxWidth="250.0">
            <VBox.margin>
                <Insets bottom="5.0" />
            </VBox.margin></TextField>
        <Label prefWidth="250.0" text="Password" />
        <PasswordField fx:id="password" maxWidth="250.0">
            <VBox.margin>
                <Insets bottom="10.0" />
            </VBox.margin>
        </PasswordField>
      <CheckBox fx:id="admin" mnemonicParsing="false" prefHeight="17.0" prefWidth="102.0" text="admin user?" />
        <HBox alignment="CENTER" prefHeight="41.0" prefWidth="395.0" spacing="20.0">
            <children>
                <Button fx:id="createUser" mnemonicParsing="false" text="Create user" />
                <Button fx:id="close" mnemonicParsing="false" text="Close" />
            </children>
        </HBox>
    </children>
</VBox>
