<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="10.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label fx:id="status" />
      <Label layoutX="83.0" layoutY="72.0" prefHeight="17.0" prefWidth="250.0" text="First Name" />
      <TextField fx:id="editFirstName" layoutX="83.0" layoutY="64.0" maxWidth="250.0" />
      <Label layoutX="85.0" layoutY="61.0" prefHeight="17.0" prefWidth="250.0" text="Last Name" />
      <TextField fx:id="editLastName" layoutX="85.0" layoutY="101.0" maxWidth="250.0" />
      <Label prefHeight="17.0" prefWidth="250.0" text="Email Address" />
      <TextField fx:id="editEmail" maxWidth="250.0" />
      <Label prefHeight="17.0" prefWidth="250.0" text="Username" />
      <TextField fx:id="editUsername" maxWidth="250.0">
         <VBox.margin>
            <Insets bottom="5.0" />
         </VBox.margin>
      </TextField>
      <CheckBox fx:id="editAdmin" mnemonicParsing="false" onAction="#isAdminHandler" prefHeight="17.0" prefWidth="102.0" text="admin user?" />
      <HBox alignment="CENTER" prefHeight="41.0" prefWidth="395.0" spacing="20.0">
         <children>
            <Button fx:id="editUser" mnemonicParsing="false" text="Create user" />
            <Button fx:id="close" mnemonicParsing="false" onAction="#closeEditProfileHandler" text="Close" />
         </children>
      </HBox>
   </children>
</VBox>
